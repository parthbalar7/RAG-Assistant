# ── RAG Assistant v2 Configuration ──

# Required
RAG_ANTHROPIC_API_KEY=sk-ant-your-key-here

# LLM
RAG_LLM_MODEL=claude-sonnet-4-20250514
RAG_LLM_MAX_TOKENS=2048
RAG_LLM_TEMPERATURE=0.1

# Embeddings (local model - downloads automatically)
RAG_EMBEDDING_MODEL=all-MiniLM-L6-v2

# Vector store
RAG_CHROMA_PERSIST_DIR=./data/chroma_db
RAG_COLLECTION_NAME=tech_docs

# Chunking
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=64

# Retrieval
RAG_TOP_K=10
RAG_RERANK_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.25

# Hybrid search weights
RAG_BM25_WEIGHT=0.3
RAG_VECTOR_WEIGHT=0.7

# Agent
RAG_AGENT_MAX_STEPS=5

# Memory — Long-term conversation memory (token-optimized)
RAG_MEMORY_ENABLED=true
RAG_MEMORY_TOP_K=5
RAG_MEMORY_AUTO_EXTRACT=true
RAG_MEMORY_AUTO_SUMMARIZE=true
RAG_MEMORY_EXTRACTION_MODEL=claude-haiku-3-5-20241022
RAG_MEMORY_EXTRACT_INTERVAL=3
RAG_MEMORY_MIN_ANSWER_LENGTH=100

# Token Optimization — Reduce API costs
RAG_MAX_CONTEXT_CHUNKS=5
RAG_MAX_CHUNK_PREVIEW_TOKENS=300
RAG_MAX_HISTORY_TURNS=6

# Knowledge Integrity & Risk Radar
RAG_INTEGRITY_SCAN_MAX_CHUNKS=1200
RAG_INTEGRITY_MAX_ISSUES=50

# PageIndex — Local tree-indexed PDF retrieval (uses your Anthropic key)
RAG_PAGEINDEX_ENABLED=false

# Auth
RAG_JWT_SECRET=djknbzjfbndbndjsfnbshdb09f8f7sdfn23u4t
RAG_JWT_EXPIRY_HOURS=72

# Database
RAG_DATABASE_PATH=./data/rag_assistant.db

# API
RAG_API_HOST=0.0.0.0
RAG_API_PORT=8000
